# Active Exchange
ACTIVE_EXCHANGE=binance  # binance or hyperliquid

# Binance Spot Testnet
# Get credentials from: https://testnet.binance.vision/
BINANCE_TESTNET=true
BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_api_secret
# BINANCE_ENDPOINT=https://testnet.binance.vision  # Optional

# Hyperliquid API (Testnet)
HYPERLIQUID_API_KEY=your_testnet_api_key
HYPERLIQUID_API_SECRET=your_testnet_api_secret

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# OpenAI (for vision analysis - optional)
OPENAI_API_KEY=your_openai_api_key

# Twitter API v2 (Essential/Elevated access)
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# CryptoPanic API (Free tier available)
# Get API key from: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key

# Trading Mode
TRADING_MODE=testnet  # testnet or production
DRY_RUN=true  # true for paper trading
USE_REAL_SENTIMENT=true  # true for real sentiment analysis, false for mock
USE_REAL_MARKET_DATA=true  # true for real market data, false for synthetic
USE_REAL_VALIDATION=true  # true for real slippage/liquidity validation, false for mock

# Trading Pairs
TRADING_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT
RISK_PER_TRADE=0.02
DAILY_LOSS_LIMIT=0.05
